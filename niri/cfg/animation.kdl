animations {
    workspace-switch {
        // Stiffness أعلى يعني استجابة فورية بدون تأخير
        spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001
    }
    window-open {
        duration-ms 150
        curve "ease-out-quad"
    }
    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }
    window-movement {
        spring damping-ratio=1.0 stiffness=1200 epsilon=0.0001
    }
    // باقي الـ animations خليهم زي ما هما عشان التوازن
}
